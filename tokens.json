        ],
        "hex": "#c9a96e"
      }
    },
    "warning": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.706,
          0.325,
          0.035
        ],
        "hex": "#b45309"
      }
    },
    "error": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.498,
          0.114,
          0.114
        ],
        "hex": "#7f1d1d"
      }
    },
    "success": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.247,
          0.384,
          0.071
        ],
        "hex": "#3f6212"
      }
    }
  },
  "spacing": {
    "$type": "dimension",
    "sm": {
      "$value": {
        "value": 4,
        "unit": "px"
      }
    },
    "md": {
      "$value": {
        "value": 8,
        "unit": "px"
      }
    },
    "lg": {
      "$value": {
        "value": 16,
        "unit": "px"
      }
    },
    "xl": {
      "$value": {
        "value": 24,
        "unit": "px"
      }
    }
  },
  "rounded": {
    "$type": "dimension",
    "sm": {
      "$value": {
        "value": 2,
        "unit": "px"
      }
    },
    "md": {
      "$value": {
        "value": 4,
        "unit": "px"
      }
    },
    "lg": {
      "$value": {
        "value": 6,
        "unit": "px"
      }
    }
  },
  "typography": {
    "heading": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": {
          "value": 1.5,
          "unit": "rem"
        },
        "fontWeight": 600,
        "letterSpacing": {
          "value": -0.02,
          "unit": "em"
        }
      }
    },
    "body": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": {
          "value": 1,
          "unit": "rem"
        },
        "fontWeight": 400,
        "letterSpacing": {
          "value": 0,
          "unit": "em"
        }
      }
    },
    "code": {
      "$type": "typography",
      "$value": {
        "fontFamily": "JetBrains Mono",
        "fontSize": {
          "value": 0.875,
          "unit": "rem"
        },
        "fontWeight": 400,
        "letterSpacing": {
          "value": 0,
          "unit": "em"
        }
      }
    },
    "label": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": {
          "value": 0.75,
          "unit": "rem"
        },
        "fontWeight": 500,
        "letterSpacing": {
          "value": 0.08,
          "unit": "em"
        }
      }
    }
  }
}
