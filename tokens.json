        ],
        "hex": "#475569"
      }
    },
    "flow": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.392,
          0.455,
          0.545
        ],
        "hex": "#64748b"
      }
    },
    "water": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.945,
