{
  "$schema": "https://www.designtokens.org/schemas/2025.10/format.json",
  "$description": "Silent infrastructure. Brass truth hanging in a slate void.",
  "color": {
    "$type": "color",
    "primary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.059,
          0.09,
          0.165
        ],
        "hex": "#0f172a"
      }
    },
    "secondary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.278,
          0.333,
          0.412
        ],
        "hex": "#475569"
      }
    },
    "tertiary": {
